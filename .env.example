# =============================
# Database
# =============================
DATABASE_URL=postgresql://user:password@localhost:5432/gantt_diary

# =============================
# Auth (NextAuth.js)
# =============================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# =============================
# AI Provider
# "openai" または "ollama" を選択
# =============================
AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Ollama (ローカルLLM) ---
# AI_PROVIDER=ollama の場合に設定
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =============================
# File Storage (S3 互換)
# =============================
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=   # Cloudflare R2 等の場合に設定
