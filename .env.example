# =============================
# Database (Supabase)
# 取得場所: Supabase ダッシュボード → Connect → URI
# =============================
DATABASE_URL=postgresql://postgres:パスワード@db.xxxx.supabase.co:5432/postgres

# =============================
# Auth (NextAuth.js)
# =============================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# =============================
# AI Provider
# "cloud"（OpenAI等） または "local"（Ollama）を選択
# =============================
AI_PROVIDER=cloud

# --- OpenAI (AI_PROVIDER=cloud の場合) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Ollama ローカルLLM (AI_PROVIDER=local の場合) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
